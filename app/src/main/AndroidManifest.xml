<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Needed to list installed apps for the per-app DNS / VPN allow-list.
         Sideloaded builds are unaffected; a Play Store release of this feature
         requires declaring the "Core app functionality" use-case in Play Console. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Not granted at install time — enables a zero-VPN "system DNS" mode (Android's
         native Private DNS setting) when granted once via ADB:
         adb shell pm grant <applicationId> android.permission.WRITE_SECURE_SETTINGS
         Without this grant, Barndoor falls back to the VPN-based proxy automatically. -->
    <uses-permission android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <application
        android:name=".BarndoorApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.Barndoor"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.Barndoor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- DNS changer VPN service (local DNS proxy, no root / no special permission) -->
        <service
            android:name=".dns.DnsVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:label="@string/dns_service_label">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Local DNS proxy for custom DNS selection" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Quick Settings tile: cycle / toggle DNS server.
             Deliberately standard (non-active) mode: onStartListening() then fires
             automatically every time the panel opens, guaranteeing a fresh state
             check (see DnsRepository.syncWithReality) instead of only refreshing
             when something remembers to call requestListeningState(). -->
        <service
            android:name=".dns.DnsTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_dns"
            android:label="@string/tile_dns_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>
