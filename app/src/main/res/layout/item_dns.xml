<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <RadioButton
        android:id="@+id/dnsRadio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="false"
        android:focusable="false"
        app:buttonTint="@color/barn_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp">

        <TextView
            android:id="@+id/dnsName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/barn_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dnsAddresses"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/barn_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/dnsDelete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:src="@drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_delete" />

</LinearLayout>
