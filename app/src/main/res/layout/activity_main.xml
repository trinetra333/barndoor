<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/tagline"
            android:textSize="14sp" />

        <!-- Hotspot section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hotspot_section"
            android:textStyle="bold"
            android:textSize="18sp" />

        <Switch
            android:id="@+id/hotspotSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable hotspot"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/hotspotStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: unknown"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Filtering section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filtering_section"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filtering_disclaimer"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/blockedDomainsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Comma-separated domains to block (e.g. example.com, ads.net)" />

        <Button
            android:id="@+id/saveFilterButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save filter list"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Alerts section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/alerts_section"
            android:textStyle="bold"
            android:textSize="18sp" />

        <Switch
            android:id="@+id/alertsSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notify me when a new device joins"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
